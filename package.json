{
  "name": "qiuai",
  "productName": "QiuAi",
  "version": "1.2.0",
  "private": true,
  "description": "Desktop image generation tool for gpt-image-2.",
  "author": {
    "name": "QiuAi Team"
  },
  "main": "main/main.js",
  "type": "commonjs",
  "scripts": {
    "dev": "concurrently \"vite --config renderer/vite.config.js\" \"wait-on tcp:5173 && cross-env NODE_ENV=development VITE_DEV_SERVER_URL=http://127.0.0.1:5173 electron .\"",
    "build:renderer": "vite build --config renderer/vite.config.js",
    "package:win": "npm run build:renderer && electron-builder --win nsis portable --x64",
    "test": "vitest run",
    "lint": "eslint main renderer/src shared tests vitest.config.mjs --ext .js,.vue,.mjs"
  },
  "build": {
    "appId": "com.qiuai.desktop",
    "directories": {
      "output": "../package/QiuAi-win"
    },
    "files": [
      "main/**/*",
      "renderer/dist/**/*",
      "shared/**/*",
      "package.json"
    ],
    "win": {
      "signAndEditExecutable": false,
      "icon": "build/icons/app-icon.ico",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "installerIcon": "build/icons/app-icon.ico",
      "uninstallerIcon": "build/icons/app-icon.ico",
      "runAfterFinish": true
    }
  },
  "dependencies": {
    "archiver": "^7.0.1",
    "axios": "1.6.8",
    "electron-store": "8.2.0",
    "vue": "3.5.13"
  },
  "devDependencies": {
    "@eslint/eslintrc": "2.1.4",
    "@vitejs/plugin-vue": "5.0.4",
    "@vue/compiler-sfc": "3.5.13",
    "concurrently": "8.2.2",
    "cross-env": "7.0.3",
    "electron": "30.0.9",
    "electron-builder": "^24.13.3",
    "eslint": "8.57.0",
    "eslint-plugin-vue": "9.24.0",
    "vite": "5.2.8",
    "vitest": "1.6.0",
    "wait-on": "7.2.0"
  }
}
